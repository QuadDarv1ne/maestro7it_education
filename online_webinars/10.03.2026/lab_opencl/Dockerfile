# =============================================================================
# Dockerfile для проекта "Вычисления на GPU с OpenCL"
# =============================================================================
# Этот Dockerfile создаёт воспроизводимую среду для сборки и тестирования
#
# Требования:
#   - Docker 20.10+ (с поддержкой GPU для NVIDIA)
#   - NVIDIA Docker runtime (опционально, для GPU тестов)
#
# Сборка:
#   docker build -t gpu-lab:latest .
#
# Запуск (CPU только):
#   docker run --rm gpu-lab:latest
#
# Запуск (с GPU NVIDIA):
#   docker run --rm --gpus all gpu-lab:latest
#
# Запуск с интерактивным доступом:
#   docker run --rm -it --gpus all gpu-lab:latest bash
# =============================================================================

FROM ubuntu:22.04

# Предотвращение интерактивных запросов при установке
ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Europe/Moscow

# Метаданные
LABEL maintainer="GPU Lab Contributors"
LABEL description="Лабораторная работа: Вычисления на GPU с OpenCL"
LABEL version="1.1.0"

# =============================================================================
# Установка системных зависимостей
# =============================================================================

RUN apt-get update && apt-get install -y --no-install-recommends \
    # Базовые инструменты
    build-essential \
    cmake \
    cmake-data \
    git \
    wget \
    curl \
    ca-certificates \
    \
    # OpenCL
    ocl-icd-opencl-dev \
    ocl-icd-libopencl1 \
    mesa-opencl-icd \
    clinfo \
    \
    # Компиляторы
    gcc \
    g++ \
    clang \
    clang-format \
    clang-tidy \
    \
    # Инструменты анализа
    cppcheck \
    valgrind \
    \
    # Python для скриптов
    python3 \
    python3-pip \
    python3-dev \
    \
    # Документация
    doxygen \
    graphviz \
    \
    # Утилиты
    lsb-release \
    software-properties-common \
    && rm -rf /var/lib/apt/lists/*

# =============================================================================
# Установка Python зависимостей
# =============================================================================

RUN pip3 install --no-cache-dir \
    matplotlib \
    pandas \
    numpy

# =============================================================================
# Создание пользователя (не root)
# =============================================================================

RUN groupadd -r gpulab && useradd -r -g gpulab -m gpulab
USER gpulab
WORKDIR /home/gpulab

# =============================================================================
# Копирование исходного кода
# =============================================================================

COPY --chown=gpulab:gpulab . /home/gpulab/

# =============================================================================
# Сборка проекта
# =============================================================================

RUN mkdir -p build && \
    cd build && \
    cmake .. -DCMAKE_BUILD_TYPE=Release -DBUILD_TESTS=ON && \
    cmake --build . --parallel $(nproc)

# =============================================================================
# Запуск тестов при сборке
# =============================================================================

RUN cd build && ctest --output-on-failure

# =============================================================================
# Переключение обратно на root для установки NVIDIA драйверов (опционально)
# =============================================================================

USER root

# =============================================================================
# NVIDIA Container Toolkit (опционально, для GPU поддержки)
# =============================================================================
# Для использования GPU в Docker:
# 1. Установите NVIDIA Docker: https://docs.nvidia.com/datacenter/cloud-native/container-toolkit/install-guide.html
# 2. Запускайте с флагом --gpus all
#
# Примечание: Драйверы NVIDIA должны быть установлены на хосте
# =============================================================================

# =============================================================================
# Финальная конфигурация
# =============================================================================

USER gpulab
WORKDIR /home/gpulab/build

# Переменные окружения
ENV PATH="/home/gpulab/.local/bin:${PATH}"

# =============================================================================
# Health check
# =============================================================================

HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD cmake --build . --target test_sieve || exit 1

# =============================================================================
# Точки монтирования (опционально)
# =============================================================================

VOLUME ["/home/gpulab/benchmark_results"]

# =============================================================================
# Команда по умолчанию
# =============================================================================

CMD ["ctest", "--verbose"]

# =============================================================================
# Примеры использования
# =============================================================================
#
# 1. Сборка образа:
#    docker build -t gpu-lab:latest .
#
# 2. Запуск всех тестов:
#    docker run --rm gpu-lab:latest
#
# 3. Интерактивный режим:
#    docker run --rm -it gpu-lab:latest bash
#
# 4. Запуск бенчмарков:
#    docker run --rm -v $(pwd)/results:/home/gpulab/benchmark_results gpu-lab:latest \
#        ../scripts/benchmark.sh all
#
# 5. С GPU (NVIDIA):
#    docker run --rm --gpus all gpu-lab:latest
#
# 6. Разработка с монтированием исходников:
#    docker run --rm -it -v $(pwd):/home/gpulab gpu-lab:latest bash
#
# =============================================================================
